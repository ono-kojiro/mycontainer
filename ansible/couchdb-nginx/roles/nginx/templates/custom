server {
    server_name {{ server_addr }};

    include /etc/nginx/includes/ssl.conf;

    root /var/www/html;

    index index.html index.htm index.nginx-debian.html;

    location / {
        try_files $uri $uri/ =404;
    }
   
    location /couchdb/ {
        include /etc/nginx/includes/couchdb.conf;
    }
}

